# --- GoHighLevel (LeadConnector) API -----------------------------------
# Private Integration token: GHL sub-account → Settings → Private Integrations
# → create one with scopes: contacts.write, contacts.readonly,
# locations/customValues.readonly (add customValues.write if you want to
# manage them via API later).
GHL_API_TOKEN=

# Sub-account (location) id: Settings → Business Profile, or from the GHL URL.
GHL_LOCATION_ID=

# Optional: a GHL workflow "Inbound Webhook" trigger URL. Every lead payload
# (contact + qualification answers + score/tier/fit + UTM + page context) is
# mirrored here, so workflows can run even without custom-field mapping.
GHL_WEBHOOK_URL=

# Optional: if set, the qualification popup and /qualify page embed this
# GHL-hosted survey instead of the built-in native form.
NEXT_PUBLIC_GHL_SURVEY_URL=

# Optional: Audit Pipeline ids. When set, qualified audit applications are
# dropped straight into this pipeline stage as Opportunities (T1 $3000 /
# T2 $5000 / T3 $0 custom) — no GHL workflow step needed for it.
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=

# Secret for POST /api/revalidate?secret=... — busts the cached GHL content
# so edits to the Website * JSON custom values appear immediately.
REVALIDATE_SECRET=
